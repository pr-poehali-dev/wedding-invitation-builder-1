{
  "tests": [
    {
      "name": "Save wedding — forbidden without token",
      "method": "POST",
      "path": "/",
      "expectedStatus": 403
    },
    {
      "name": "Save guest — missing name returns 400",
      "method": "POST",
      "path": "/?mode=guest",
      "body": {"attending": "yes"},
      "expectedStatus": 400
    },
    {
      "name": "Save guest — invalid attending returns 400",
      "method": "POST",
      "path": "/?mode=guest",
      "body": {"name": "Иван", "attending": "maybe"},
      "expectedStatus": 400
    }
  ]
}
